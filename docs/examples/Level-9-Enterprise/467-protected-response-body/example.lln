/// example: 467-protected-response-body
/// test_status: draft
/// level: 9
/// concept: Protected value in response body requires policy
/// expected_diagnostics: LLN-GOV-003

secure flow getProfile(readonly request: Request) -> GetProfileResult

contract {
  types {
    type GetProfileResult = Result<Response, ApiError>
  }
}
effects [database.read] {
  let patient = PatientsDB.findById(request.patientId)?
  return Ok(Response.ok({
    email: patient.email
  }))
}
