/// example: 467-protected-response-body
/// level: 9
/// concept: Protected value in response body requires policy
/// expected_diagnostics: LLN-GOV-003

secure flow getProfile(readonly req: Request) -> Result<Response, ApiError>
effects [database.read] {
  let patient = PatientsDB.findById(req.patientId)?
  return Ok(Response.ok({
    email: patient.email
  }))
}
