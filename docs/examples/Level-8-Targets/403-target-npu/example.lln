/// example: 403-target-npu
/// level: 8
/// concept: explicit NPU compute target with GPU fallback
/// expected_diagnostics: none
/// ai_rule: Use compute target npu for on-device edge inference; fall back to gpu before cpu for performance.

guarded flow runOnNpu(input: Tensor<Float32, [1, 768]>) -> Result<Tensor<Float32, [1, 256]>, AiError>
  with effects [ai.inference]
{
  compute target npu { fallback gpu }
  return ProjectionModel.forward(input)?
}
