/// example: 154-validate-email
/// level: 4
/// concept: validating unsafe email to protected Email
/// expected_diagnostics: none
/// ai_rule: Email values come from validate.email(). The ? propagates validation failure.

secure flow createUser(req: Request) -> Result<UserId, UserError>
  with effects [database.write, audit.write]
{
  unsafe let rawEmail: String = req.body.email
  let email: protected Email = validate.email(rawEmail)?
  let id = UsersDB.insert({ email: email })?
  AuditLog.write({ action: "createUser", id: id })
  return Ok(id)
}
