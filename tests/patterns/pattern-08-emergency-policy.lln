// EXPECT: ACCEPT
// Pattern 8 — Emergency Policy Overlay (drcm_core_v1 — future)
// Reference: docs/Knowledge-Bases/logicn-architecture-patterns.md
//
// policy { emergency { ... } } is DRCM Phase 4 — not yet in Stage A.
// This file shows the stable shell (accepted today) with the emergency block
// in comments. When Phase 4 ships, unwrap the @experimental_profile block.
//
// The Monotonic Rule (M-003): emergency overlays are ONE-WAY.
// Once deny network.outbound fires — it cannot be reversed in this session.
// Overlays escalate (Tier 1 → Tier 2 → Tier 3) but never de-escalate.
// The operator must restart the DSS/Wasmtime session to restore capabilities.

type MonitoredPayload  = record { order_id: String, amount: Int }
type ProcessingResult  = record { status: String, message: String }
type ProcessingError   = enum { PolicyViolation InvariantFailure MemoryPressure ServiceError }

secure flow monitoredPaymentProcessor(readonly payload: MonitoredPayload)
  -> Result<ProcessingResult, ProcessingError>
contract {
  intent { "Process payments with automatic security posture management on anomaly detection." }
  effects { database.write, network.outbound, audit.write, secret.read }
  secrets { bind "PAYMENT_KEY" }
  audit   { require cryptographic_state_hash }
  limits  { memory 64mb request_time 10s }
}
// DRCM Phase 4 — policy {} is a SEPARATE block between contract and body (not inside contract {}).
// Confirmed design: signature → contract {} → policy {} → { body }
// policy {} contains runtime monotonic overlay rules. Not a contract sub-block.
// When @experimental_profile ships (task #51), unwrap this:
//
// policy {
//   emergency {
//     on invariant_failure {
//       deny network.outbound
//       require local_only_execution
//       audit { level cryptographic_state_hash }
//     }
//     on memory_pressure_high {
//       deny network.outbound
//       deny database.write
//       flush ephemeral_scratchpad
//     }
//     on secret_breach_detected {
//       zeroize all_key_material
//       terminate execution
//       emit audit_final_entry
//     }
//   }
// }
{
  if payload.amount <= 0 {
    return Err(ProcessingError.InvariantFailure)
  }

  // Pre-flight check before cross-boundary call
  let receipt = security::interim::pre_flight_check(
    "monitoredPaymentProcessor",
    "payment_service::process",
    String.length(payload.order_id)
  )

  if !receipt.is_approved {
    return Err(ProcessingError.PolicyViolation)
  }

  let result = payment_service::process(payload.order_id, payload.amount)

  security::interim::post_flight_cleanup(receipt)

  AuditLog.write("PaymentProcessed: " + payload.order_id)

  return Ok(ProcessingResult { status: "ok", message: "payment processed" })
}
