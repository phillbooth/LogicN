/// example: 112-local-fn-cannot-declare-effects
/// level: 3
/// concept: local fn cannot declare its own effects
/// expected_diagnostics: LLN-SEC-014
/// ai_rule: Only flow declarations may declare effects. Local fn cannot have with effects [...].

guarded flow processOrder(order: Order) -> Result<Unit, ProcessError>
  with effects [database.write]
{
  fn save(o: Order) -> Result<Unit, SaveError>
    with effects [database.write]
  {
    return OrdersDB.insert(o)
  }
  return save(order)
}
